#!/bin/bash
# Used by ttyd to attach to a tmux session running
# `claude --dangerously-skip-permissions`. Same session name → re-attach;
# different names → independent parallel claudes.
#
# Session-name precedence:
#   $1 (URL arg passed via ttyd --url-arg)
#   $SESSION env var
#   default "claude"
#
# Before attaching, dump the existing pane's scrollback to stdout so xterm.js
# (which starts with an empty buffer on each page load) lands with conversation
# history visible.
SESSION="${1:-${SESSION:-claude}}"
# Strip anything that isn't safe for a tmux session name. Without this the URL
# arg could inject control chars or shell metacharacters.
SESSION=$(echo "$SESSION" | tr -cd 'a-zA-Z0-9_-')
[ -z "$SESSION" ] && SESSION=claude

# Claude Code refuses to launch a second instance from inside another Claude
# session — its check fires when CLAUDECODE is set in the environment.
# Per Claude's own error message, the bypass is to UNSET CLAUDECODE so the
# new session doesn't appear to be nested inside another one.
# User-spawned sessions also get their own workdir so they show up as
# independent projects in Claude's UI, with the trust dialog pre-accepted
# so each new tab opens straight into the chat.
unset CLAUDECODE CLAUDE_CODE_SSE_PORT CLAUDE_CODE_ENTRYPOINT
if [ "$SESSION" = "claude" ]; then
    WORKDIR="$HOME"
else
    WORKDIR="$HOME/.claude-sessions/$SESSION"
    mkdir -p "$WORKDIR"
    python3 - "$WORKDIR" <<'PY' 2>/dev/null || true
import json, os, sys
path = os.path.expanduser("~/.claude.json")
if os.path.exists(path):
    with open(path) as f: d = json.load(f)
    d.setdefault("projects", {}).setdefault(sys.argv[1], {})["hasTrustDialogAccepted"] = True
    with open(path, "w") as f: json.dump(d, f, indent=2)
PY
fi
cd "$WORKDIR" || cd /

# Also scrub CLAUDECODE from the tmux server's saved env so it doesn't leak
# into future sessions. The tmux SERVER captures env at first-start; new-session
# spawns its child shell from that snapshot, not from our wrapper's env. Without
# this scrub, the inner bash (below) sees a CLAUDECODE inherited from whoever
# originally launched the tmux server. -u removes the variable entirely.
tmux set-environment -gu CLAUDECODE       2>/dev/null
tmux set-environment -gu CLAUDE_CODE_SSE_PORT  2>/dev/null
tmux set-environment -gu CLAUDE_CODE_ENTRYPOINT 2>/dev/null

if tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux capture-pane -p -t "$SESSION" -S -100000 -E -1 2>/dev/null
fi
# Belt-and-suspenders: also `unset CLAUDECODE` inside the bash that actually
# exec()s claude — covers the case where the tmux server env scrub above
# raced or somehow didn't take.
exec tmux new-session -A -s "$SESSION" -c "$WORKDIR" -- \
    bash -c 'unset CLAUDECODE CLAUDE_CODE_SSE_PORT CLAUDE_CODE_ENTRYPOINT; while true; do "$@"; status=$?; echo; echo "[pwa-claude-tmux] claude exited (status=$status). Press any key to restart, or Ctrl-C to drop to a shell."; read -t 5 -n 1 && continue || echo "auto-restarting in 1s..."; sleep 1; done' \
    -- claude --dangerously-skip-permissions
